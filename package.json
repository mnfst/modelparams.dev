{
  "name": "modelparams.dev",
  "version": "0.1.0",
  "description": "An open catalog of LLM model parameters. The community-maintained source of truth for every knob you can turn.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnfst/modelparameters.dev.git"
  },
  "homepage": "https://modelparams.dev",
  "bugs": {
    "url": "https://github.com/mnfst/modelparameters.dev/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsx src/build/build.ts",
    "dev": "tsx watch src/server/dev.ts",
    "validate": "tsx src/data/validate.ts",
    "guard:params": "tsx src/data/check-removals.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "autoprefixer": "^10.4.19",
    "chokidar": "^3.6.0",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{yaml,yml,json,md}": [
      "prettier --write"
    ]
  }
}
