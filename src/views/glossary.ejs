<%- include("partials/breadcrumbs", { items: [
  { name: "Home", href: "/" },
  { name: "Glossary" }
] }) %>

<section class="pt-6">
  <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">LLM parameter glossary</h1>
  <p class="mt-3 max-w-2xl text-pretty text-sm text-slate-600 dark:text-slate-300 sm:text-base"><%= intro %></p>
</section>

<% for (const groupItem of groups) { %>
<section class="mt-10" aria-label="<%= groupItem.label %> parameters">
  <h2 class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
    <span class="inline-flex h-4 w-4 items-center justify-center text-slate-400 dark:text-slate-500" aria-hidden="true"><%- helpers.paramGroupIcon(groupItem.group) %></span>
    <%= groupItem.label %>
  </h2>
  <dl class="mt-3 divide-y divide-slate-100 dark:divide-slate-800">
    <% for (const entry of groupItem.entries) { %>
    <div class="py-3 sm:flex sm:gap-6">
      <dt class="sm:w-64 sm:shrink-0">
        <span class="font-medium text-slate-900 dark:text-slate-100"><%= entry.label %></span>
        <code class="mt-0.5 block font-mono text-xs text-slate-500 dark:text-slate-400"><%= entry.path %></code>
        <span class="mt-1 inline-block text-[11px] uppercase tracking-wide text-slate-400 dark:text-slate-500"><%= entry.types.join(" / ") %> · <%= entry.modelCount %> model<%= entry.modelCount === 1 ? "" : "s" %></span>
      </dt>
      <dd class="mt-1 flex-1 text-sm text-slate-700 dark:text-slate-300 sm:mt-0">
        <p><%= entry.description %></p>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
          Supported by:
          <% entry.providers.forEach(function (provider, i) { %><a href="<%= helpers.providerPagePath(provider) %>" class="underline hover:text-slate-700 dark:hover:text-slate-200"><%= helpers.providerLabel(provider) %></a><%= i < entry.providers.length - 1 ? ", " : "" %><% }) %>
        </p>
      </dd>
    </div>
    <% } %>
  </dl>
</section>
<% } %>

<section class="mt-10 border-t border-slate-200 pt-6 text-sm dark:border-slate-800">
  <a href="/" class="text-slate-600 underline hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">Back to the full catalog</a>
</section>
