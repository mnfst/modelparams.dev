<%
  const providerLogo = models.length > 0 ? helpers.logoFor(models[0].provider) : "";
%>
<%- include("partials/breadcrumbs", { items: [
  { name: "Home", href: "/" },
  { name: providerName }
] }) %>

<section class="pt-6">
  <h1 class="font-bold tracking-tight"><%= providerName %> model parameters</h1>
  <p class="mt-3 max-w-2xl text-pretty text-sm text-slate-600 dark:text-slate-300 sm:text-base"><%= intro %></p>
</section>

<section class="mt-8" aria-label="<%= providerName %> models">
  <div class="flex items-center justify-between">
    <h2 class="text-slate-900 dark:text-slate-100"><%= models.length %> model<%= models.length === 1 ? "" : "s" %></h2>
    <div class="flex items-center gap-1">
      <button type="button" data-view-mode="grid" data-active="true" aria-pressed="true" aria-label="Grid view"
        class="rounded p-1.5 text-slate-400 hover:text-slate-600 data-[active=true]:bg-warm-hover data-[active=true]:text-slate-900 dark:hover:text-slate-300 dark:data-[active=true]:bg-slate-800 dark:data-[active=true]:text-slate-100">
        <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <rect x="1" y="1" width="6" height="6" rx="0.5" /><rect x="9" y="1" width="6" height="6" rx="0.5" /><rect x="1" y="9" width="6" height="6" rx="0.5" /><rect x="9" y="9" width="6" height="6" rx="0.5" />
        </svg>
      </button>
      <button type="button" data-view-mode="list" aria-pressed="false" aria-label="List view"
        class="rounded p-1.5 text-slate-400 hover:text-slate-600 data-[active=true]:bg-warm-hover data-[active=true]:text-slate-900 dark:hover:text-slate-300 dark:data-[active=true]:bg-slate-800 dark:data-[active=true]:text-slate-100">
        <svg viewBox="0 0 16 16" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <rect x="1" y="1.5" width="14" height="3" rx="0.5" /><rect x="1" y="6.5" width="14" height="3" rx="0.5" /><rect x="1" y="11.5" width="14" height="3" rx="0.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Grid view -->
  <div data-provider-grid class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% for (const model of models) { %>
    <a
      href="<%= helpers.modelPagePath(model) %>"
      class="flex flex-col border border-slate-200 bg-white p-4 transition-colors hover:border-slate-300 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700"
    >
      <span class="truncate text-sm font-medium text-slate-900 dark:text-slate-100"><%= helpers.modelLabel(model) %></span>
      <div class="mt-3 flex items-center gap-2">
        <% if (model.authType === "subscription") { %>
        <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-[10px] font-medium text-emerald-800 dark:bg-emerald-900/50 dark:text-emerald-200"><%= helpers.authLabel(model.authType) %></span>
        <% } %>
        <span class="rounded bg-warm-tag px-1.5 py-0.5 text-[10px] tabular-nums text-slate-500 dark:bg-slate-800 dark:text-slate-400"><%= model.params.length %> param<%= model.params.length === 1 ? "" : "s" %></span>
      </div>
    </a>
    <% } %>
  </div>

  <!-- List view -->
  <div data-provider-list class="model-list mt-4 hidden flex-col">
    <% for (const model of models) { %>
    <a
      href="<%= helpers.modelPagePath(model) %>"
      class="model flex items-center border border-slate-200 bg-white px-4 py-3 transition-colors hover:border-slate-300 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-slate-700"
    >
      <span class="truncate text-sm font-medium text-slate-900 dark:text-slate-100"><%= helpers.modelLabel(model) %></span>
      <% if (model.authType === "subscription") { %>
      <span class="ml-3 rounded bg-emerald-100 px-1.5 py-0.5 text-[10px] font-medium text-emerald-800 dark:bg-emerald-900/50 dark:text-emerald-200"><%= helpers.authLabel(model.authType) %></span>
      <% } %>
      <span class="ml-auto shrink-0 text-xs tabular-nums text-slate-500 dark:text-slate-400"><%= model.params.length %> param<%= model.params.length === 1 ? "" : "s" %></span>
      <svg class="ml-2 h-4 w-4 shrink-0 text-slate-400" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
        <path d="M6.5 4l3.5 4-3.5 4" />
      </svg>
    </a>
    <% } %>
  </div>
</section>

<section class="mt-10 border-t border-slate-200 pt-6 dark:border-slate-800">
  <% if (otherProviders.length > 0) { %>
  <h2 class="text-slate-900 dark:text-slate-100">Other providers</h2>
  <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
    <% for (const hub of otherProviders) { %>
    <% const hubLogo = helpers.logoFor(hub.provider); %>
    <a href="<%= hub.href %>" data-provider-slug="<%= hub.provider %>" class="flex items-center gap-3 border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 transition-colors hover:border-slate-300 hover:bg-warm-hover dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100 dark:hover:border-slate-700">
      <% if (hubLogo) { %>
      <span class="provider-logo inline-flex h-5 w-5 shrink-0 items-center justify-center" aria-hidden="true"><%- hubLogo %></span>
      <% } %>
      <span class="flex-1 truncate font-medium"><%= hub.label %></span>
      <span class="shrink-0 rounded bg-warm-tag px-1.5 py-0.5 text-[10px] tabular-nums text-slate-500 dark:bg-slate-800 dark:text-slate-400"><%= hub.count %> model<%= hub.count === 1 ? "" : "s" %></span>
    </a>
    <% } %>
  </div>
  <% } %>
  <h2 class="mt-8 text-slate-900 dark:text-slate-100">Resources</h2>
  <div class="mt-3 grid grid-cols-2 text-sm lg:grid-cols-4">
    <a href="/glossary" class="inline-flex items-center justify-center gap-2 border border-slate-200 bg-white px-4 py-3 text-accent hover:bg-warm-hover hover:text-accent-hover dark:border-slate-800 dark:bg-slate-900 dark:hover:bg-slate-800 sm:-mr-px">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M8 6h9v2H8z"></path><path d="M20 2H6C4.35 2 3 3.35 3 5v14c0 1.65 1.35 3 3 3h15v-2H6c-.55 0-1-.45-1-1s.45-1 1-1h14c.55 0 1-.45 1-1V3c0-.55-.45-1-1-1m-6 14H6c-.35 0-.69.07-1 .18V5c0-.55.45-1 1-1h13v12z"></path></svg>
      Glossary
    </a>
    <a href="/" class="inline-flex items-center justify-center gap-2 border border-slate-200 bg-white px-4 py-3 text-accent hover:bg-warm-hover hover:text-accent-hover dark:border-slate-800 dark:bg-slate-900 dark:hover:bg-slate-800">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2M5 19V5h14v14z"></path><path d="M7 7h10v2H7zm0 4h10v2H7zm0 4h10v2H7z"></path></svg>
      Full catalog
    </a>
  </div>
</section>
